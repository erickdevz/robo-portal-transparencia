# Copie para .env e ajuste conforme necessário.

# Playwright
HEADLESS=true
NAV_TIMEOUT_MS=30000
QUERY_TIMEOUT_MS=60000

# Concorrência (nº de consultas simultâneas por processo)
MAX_CONCURRENT_SCRAPES=4

# Portal (raramente muda)
PORTAL_BASE_URL=https://portaldatransparencia.gov.br
BUSCA_PF_PATH=/pessoa-fisica/busca/lista

# --- Parte 2: Hiperautomação (Google Drive + Sheets) ---
# "local": grava em storage/ para demonstração/testes, sem credenciais do Google.
# "google": envia de verdade ao Drive/Sheets via service account (ver README).
GOOGLE_INTEGRATION_MODE=local
GOOGLE_CREDENTIALS_PATH=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SHEETS_ID=
LOCAL_STORAGE_DIR=storage

# URL onde a própria API está servindo — usada pelo endpoint de
# hiperautomação para chamar POST /consulta via HTTP.
ROBO_API_BASE_URL=http://localhost:8000
